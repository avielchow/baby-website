---
import LeafSprig from './illustrations/LeafSprig.astro';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/weeks/', label: 'Weekly Guide' },
  { href: '/journal/', label: 'Journal' },
  { href: '/about/', label: 'About' },
];
// Private-journal nav link removed while the section is archived
// (see _private-archive/RESTORE.md).

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href);
};
---

<header class="site-header" aria-label="Primary" transition:persist>
  <div class="container header-inner">
    <a href="/" class="wordmark" aria-label="Home">
      Our Little One
      <LeafSprig width={34} class="wordmark-sprig" />
    </a>

    <nav class="primary-nav" aria-label="Primary navigation">
      <ul>
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { 'is-active': isActive(link.href) }]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <form method="POST" action="/api/logout" class="logout-form">
      <button type="submit" class="logout-btn">Sign out</button>
    </form>
  </div>
</header>

<style>
  .site-header {
    background: var(--paper);
    border-bottom: 1px solid var(--border-hairline);
    padding-block: var(--space-1);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 600;
    font-size: 1.4rem;
    color: var(--text-primary);
    text-decoration: none;
    letter-spacing: 0.01em;
  }

  .wordmark :global(.wordmark-sprig) {
    transform: translateY(-4px);
  }

  .primary-nav {
    flex: 1;
  }

  .primary-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-half);
    flex-wrap: wrap;
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.35em 0.9em;
    border-radius: var(--radius-pill);
    transition: background 0.15s ease, color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--sage-deep);
    background: var(--sage-wash);
  }

  .nav-link.is-active {
    color: #fff;
    background: var(--sage);
  }

  .logout-form {
    margin: 0;
  }

  .logout-btn {
    padding: 0.4em 1em;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--text-secondary);
    background: transparent;
    border: 1.5px solid var(--border-hairline);
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .logout-btn:hover {
    border-color: var(--sage);
    color: var(--sage-deep);
  }

  @media (max-width: 640px) {
    .header-inner {
      gap: var(--space-1);
    }
    .primary-nav {
      order: 3;
      flex-basis: 100%;
    }
    .primary-nav ul {
      justify-content: flex-start;
    }
  }
</style>
