---
/**
 * Click-to-load YouTube embed card. Shows thumbnail + title + channel;
 * the privacy-enhanced (youtube-nocookie) iframe is injected only on tap,
 * so no YouTube scripts or cookies load for viewers who never press play.
 */
interface Props {
  title: string;
  url: string;
  channel: string;
}

const { title, url, channel } = Astro.props;

function videoId(u: string): string | null {
  const m = u.match(/(?:youtube\.com\/watch\?(?:.*&)?v=|youtu\.be\/|youtube\.com\/embed\/)([\w-]{11})/);
  return m ? m[1] : null;
}

const id = videoId(url);
const thumb = id ? `https://i.ytimg.com/vi/${id}/hqdefault.jpg` : null;
---

{id && (
  <div class="video-card" data-video-id={id}>
    <button type="button" class="video-card-btn" aria-label={`Play video: ${title}`}>
      <span class="video-thumb-wrap">
        <img class="video-thumb" src={thumb} alt="" loading="lazy" width="480" height="360" />
        <span class="video-play" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor"><path d="M8 5.5v13l11-6.5z"/></svg>
        </span>
      </span>
      <span class="video-meta">
        <span class="video-kicker">Watch how</span>
        <span class="video-title">{title}</span>
        <span class="video-channel">{channel} · YouTube</span>
      </span>
    </button>
  </div>
)}

<script>
  // One delegated listener; survives view transitions and covers every card.
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.video-card-btn');
    if (!btn) return;
    const card = btn.closest('.video-card') as HTMLElement | null;
    const id = card?.dataset.videoId;
    if (!card || !id) return;
    const iframe = document.createElement('iframe');
    iframe.className = 'video-frame';
    iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
    iframe.title = btn.getAttribute('aria-label') ?? 'Video';
    iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
    iframe.allowFullscreen = true;
    card.replaceChildren(iframe);
    card.classList.add('is-playing');
  });
</script>

<style>
  .video-card {
    margin-top: var(--space-1);
    border-radius: var(--radius-card);
    overflow: hidden;
    background: var(--paper);
    box-shadow: var(--shadow-soft);
    max-width: 34rem;
  }

  .video-card.is-playing {
    aspect-ratio: 16 / 9;
  }

  .video-card :global(.video-frame) {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .video-card-btn {
    display: flex;
    align-items: stretch;
    width: 100%;
    padding: 0;
    border: 0;
    background: none;
    cursor: pointer;
    text-align: left;
    font-family: var(--font-body);
  }

  .video-thumb-wrap {
    position: relative;
    flex-shrink: 0;
    width: 11rem;
    display: block;
  }

  .video-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .video-play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: #fff;
  }

  .video-play svg {
    background: var(--sage);
    border-radius: 999px;
    padding: 0.55rem;
    width: 2.6rem;
    height: 2.6rem;
    box-shadow: 0 2px 10px rgba(61, 68, 58, 0.35);
    transition: transform 0.15s ease, background 0.15s ease;
  }

  .video-card-btn:hover .video-play svg {
    transform: scale(1.08);
    background: var(--sage-deep);
  }

  .video-meta {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.2rem;
    padding: var(--space-1);
    min-width: 0;
  }

  .video-kicker {
    font-size: var(--fs-eyebrow);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sage-deep);
  }

  .video-title {
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .video-channel {
    font-size: var(--fs-small);
    color: var(--text-secondary);
  }

  @media (max-width: 480px) {
    .video-card-btn { flex-direction: column; }
    .video-thumb-wrap { width: 100%; aspect-ratio: 16 / 9; }
  }
</style>
