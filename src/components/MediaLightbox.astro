---
/**
 * Full-screen photo lightbox, shared by the journal entries and /moments.
 * Include once per page; it activates every <img> inside any element with
 * class="lightbox-scope" (click to open, arrows / Esc / backdrop to navigate
 * and close, captions from alt text). Event delegation — survives view
 * transitions with no re-init.
 */
---

<script>
  function scopedImages(): HTMLImageElement[] {
    return Array.from(document.querySelectorAll<HTMLImageElement>('.lightbox-scope img'));
  }

  let overlay: HTMLDivElement | null = null;
  let current = 0;

  function ensureOverlay(): HTMLDivElement {
    if (overlay && document.body.contains(overlay)) return overlay;
    overlay = document.createElement('div');
    overlay.className = 'lightbox';
    overlay.setAttribute('role', 'dialog');
    overlay.setAttribute('aria-label', 'Photo viewer');
    overlay.innerHTML = `
      <button class="lightbox-close" aria-label="Close">&times;</button>
      <button class="lightbox-prev" aria-label="Previous photo">&#8249;</button>
      <figure>
        <img alt="" />
        <figcaption></figcaption>
      </figure>
      <button class="lightbox-next" aria-label="Next photo">&#8250;</button>
    `;
    overlay.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (t.closest('.lightbox-prev')) show(current - 1);
      else if (t.closest('.lightbox-next')) show(current + 1);
      else if (!t.closest('figure img')) close();
    });
    document.body.appendChild(overlay);
    return overlay;
  }

  function show(index: number) {
    const imgs = scopedImages();
    if (imgs.length === 0) return;
    current = (index + imgs.length) % imgs.length;
    const box = ensureOverlay();
    const img = box.querySelector<HTMLImageElement>('figure img')!;
    const caption = box.querySelector<HTMLElement>('figcaption')!;
    img.src = imgs[current].src;
    img.alt = imgs[current].alt;
    caption.textContent = imgs[current].alt;
    const multi = imgs.length > 1;
    box.querySelector<HTMLElement>('.lightbox-prev')!.style.display = multi ? '' : 'none';
    box.querySelector<HTMLElement>('.lightbox-next')!.style.display = multi ? '' : 'none';
    box.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    overlay?.classList.remove('open');
    document.body.style.overflow = '';
  }

  document.addEventListener('click', (e) => {
    const img = (e.target as HTMLElement).closest?.('.lightbox-scope img');
    if (!img) return;
    e.preventDefault();
    show(scopedImages().indexOf(img as HTMLImageElement));
  });

  document.addEventListener('keydown', (e) => {
    if (!overlay?.classList.contains('open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') show(current - 1);
    if (e.key === 'ArrowRight') show(current + 1);
  });
</script>

<style is:global>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
    background: rgba(15, 20, 15, 0.92);
    padding: 0.75rem;
  }

  .lightbox.open { display: flex; }

  .lightbox figure {
    margin: 0;
    max-width: calc(100vw - 1.5rem);
    max-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .lightbox figure img {
    max-width: 100%;
    max-height: calc(100dvh - 4rem);
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 6px;
  }

  .lightbox figcaption {
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.875rem;
    text-align: center;
    min-height: 1.25em;
  }

  .lightbox button {
    position: absolute;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border: 0;
    border-radius: 999px;
    width: 44px;
    height: 44px;
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox button:hover { background: rgba(255, 255, 255, 0.25); }
  .lightbox-close { top: 0.75rem; right: 0.75rem; }
  .lightbox-prev { left: 0.5rem; top: 50%; transform: translateY(-50%); }
  .lightbox-next { right: 0.5rem; top: 50%; transform: translateY(-50%); }
</style>
