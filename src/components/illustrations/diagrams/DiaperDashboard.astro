---
/** Diaper output by day of life — wet diapers count up, stool color evolves. */
const days = [
  { day: 1, wet: 1, stool: '#4A4238', stoolLabel: 'black (meconium)' },
  { day: 2, wet: 2, stool: '#54573B', stoolLabel: 'dark green' },
  { day: 3, wet: 3, stool: '#6E6B35', stoolLabel: 'green-brown' },
  { day: 4, wet: 4, stool: '#B08F3C', stoolLabel: 'mustard' },
  { day: 5, wet: 6, stool: '#D4A93E', stoolLabel: 'yellow, seedy' },
];
---

<figure class="diagram">
  <svg viewBox="0 0 720 330" width="100%" fill="none" role="img" aria-label="Diaper dashboard: wet diapers increase from about 1 on day one to 6 or more by day five, while stools shift from black meconium to yellow and seedy.">
    <rect width="720" height="330" rx="16" fill="var(--sage-wash, #E8F0E3)" />
    <g font-family="var(--font-body)">
      <text x="36" y="46" font-size="14" font-weight="800" letter-spacing="1.5" fill="var(--sage-deep, #557B4B)">WET DIAPERS</text>
      <text x="36" y="200" font-size="14" font-weight="800" letter-spacing="1.5" fill="var(--sage-deep, #557B4B)">STOOL COLOR</text>

      {days.map((d, i) => (
        <g>
          <text x={130 + i * 112} y="76" text-anchor="middle" font-size="15" font-weight="800" fill="var(--ink, #3D443A)">Day {d.day}</text>
          {Array.from({ length: d.wet }).map((_, w) => (
            <path
              d={`M${118 + i * 112 + (w % 3) * 14} ${92 + Math.floor(w / 3) * 22} c 5 7 5 12 0 15 c -5 -3 -5 -8 0 -15 Z`}
              fill="var(--sage, #6B9A5F)"
              transform="scale(1.25)"
              transform-origin={`${118 + i * 112 + (w % 3) * 14} ${92 + Math.floor(w / 3) * 22}`}
            />
          ))}
          <text x={130 + i * 112} y="162" text-anchor="middle" font-size="14" font-weight="700" fill="var(--sage-deep, #557B4B)">{d.wet}{d.day === 5 ? '+' : ''}</text>

          <circle cx={130 + i * 112} cy="228" r="17" fill={d.stool} />
          <text x={130 + i * 112} y="266" text-anchor="middle" font-size="12.5" fill="var(--ink-soft, #68715F)">{d.stoolLabel}</text>
        </g>
      ))}

      <text x="360" y="310" text-anchor="middle" font-size="15" font-weight="700" fill="var(--ink, #3D443A)">Fewer than 6 wet diapers by day 5? Call your doctor or a lactation consultant.</text>
    </g>
  </svg>
  <figcaption>The output dashboard — the most honest signal that feeding is on track. (CPS &amp; Nemours.)</figcaption>
</figure>

<style>
  .diagram {
    margin: var(--space-2) 0;
  }

  .diagram figcaption {
    margin-top: var(--space-half);
    font-size: var(--fs-small);
    color: var(--text-secondary);
  }
</style>
