---
/**
 * Per-week illustrated vignette, keyed to each week's theme:
 *   1 — first days/nights: crescent moon, stars, little cloud
 *   2 — growth & the weight check: sprout on a mound, rising sun
 *   3 — hungrier and louder: sun with sound-arcs
 *   4 — nearly one month: climbing vine with four leaves, star on top
 *   other — leaf sprig + star (fallback until a scene exists)
 */
interface Props {
  week: number;
  size?: number;
  class?: string;
}
const { week, size = 96, class: className } = Astro.props;
const maskId = `wv-moon-${Math.random().toString(36).slice(2, 8)}`;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 120 120"
  fill="none"
  aria-hidden="true"
>
  <rect width="120" height="120" rx="26" fill="var(--sage-wash, #E8F0E3)" />

  {week === 1 && (
    <g>
      <mask id={maskId}>
        <rect width="120" height="120" fill="white" />
        <circle cx="72" cy="44" r="24" fill="black" />
      </mask>
      <circle cx="60" cy="52" r="26" fill="var(--butter, #F2DFA8)" mask={`url(#${maskId})`} />
      <path d="M88 30 l2.2 5.4 5.4 2.2 -5.4 2.2 -2.2 5.4 -2.2 -5.4 -5.4 -2.2 5.4 -2.2 Z" fill="var(--sage, #6B9A5F)" />
      <circle cx="30" cy="34" r="2.5" fill="var(--rose, #E8B4B4)" />
      <ellipse cx="44" cy="92" rx="22" ry="8" fill="#FFFFFF" />
      <ellipse cx="62" cy="86" rx="15" ry="6.5" fill="#FFFFFF" />
    </g>
  )}

  {week === 2 && (
    <g>
      <circle cx="88" cy="32" r="14" fill="var(--butter, #F2DFA8)" />
      <circle cx="88" cy="32" r="20" stroke="var(--butter, #F2DFA8)" stroke-width="2" stroke-dasharray="1.5 9" stroke-linecap="round" />
      <ellipse cx="56" cy="94" rx="30" ry="9" fill="var(--leaf, #8FBC85)" opacity="0.5" />
      <path d="M56 92 Q54 68 58 54" stroke="var(--sage-deep, #557B4B)" stroke-width="3.5" stroke-linecap="round" />
      <ellipse cx="46" cy="66" rx="13" ry="6" transform="rotate(-32 46 66)" fill="var(--sage, #6B9A5F)" />
      <ellipse cx="68" cy="58" rx="13" ry="6" transform="rotate(28 68 58)" fill="var(--leaf, #8FBC85)" />
      <circle cx="58" cy="50" r="4.5" fill="var(--butter, #F2DFA8)" />
    </g>
  )}

  {week === 3 && (
    <g>
      <circle cx="44" cy="60" r="20" fill="var(--butter, #F2DFA8)" />
      <circle cx="44" cy="60" r="27" stroke="var(--butter, #F2DFA8)" stroke-width="2.5" stroke-dasharray="2 11" stroke-linecap="round" />
      <path d="M76 46 q10 14 0 28" stroke="var(--sage, #6B9A5F)" stroke-width="3.5" stroke-linecap="round" fill="none" />
      <path d="M86 38 q16 22 0 44" stroke="var(--sage, #6B9A5F)" stroke-width="3" stroke-linecap="round" fill="none" opacity="0.65" />
      <path d="M96 30 q22 30 0 60" stroke="var(--sage, #6B9A5F)" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.35" />
    </g>
  )}

  {week === 4 && (
    <g>
      <path d="M60 100 Q52 82 62 68 Q72 54 58 40 Q50 30 58 20" stroke="var(--sage-deep, #557B4B)" stroke-width="3.5" stroke-linecap="round" fill="none" />
      <ellipse cx="48" cy="86" rx="11" ry="5" transform="rotate(-30 48 86)" fill="var(--sage, #6B9A5F)" />
      <ellipse cx="74" cy="66" rx="11" ry="5" transform="rotate(26 74 66)" fill="var(--leaf, #8FBC85)" />
      <ellipse cx="46" cy="46" rx="11" ry="5" transform="rotate(-24 46 46)" fill="var(--leaf, #8FBC85)" />
      <ellipse cx="70" cy="30" rx="10" ry="4.5" transform="rotate(22 70 30)" fill="var(--sage, #6B9A5F)" />
      <path d="M58 12 l2.4 5.8 5.8 2.4 -5.8 2.4 -2.4 5.8 -2.4 -5.8 -5.8 -2.4 5.8 -2.4 Z" fill="var(--butter, #F2DFA8)" transform="translate(0,-4)" />
    </g>
  )}

  {week === 5 && (
    <g>
      {/* First smiles coming — a smiling sun */}
      <circle cx="60" cy="56" r="21" fill="var(--butter, #F2DFA8)" />
      <circle cx="60" cy="56" r="29" stroke="var(--butter, #F2DFA8)" stroke-width="2.5" stroke-dasharray="2 11" stroke-linecap="round" />
      <circle cx="52" cy="52" r="2.6" fill="var(--ink, #3D443A)" />
      <circle cx="68" cy="52" r="2.6" fill="var(--ink, #3D443A)" />
      <path d="M51 60 q9 9 18 0" stroke="var(--ink, #3D443A)" stroke-width="3" stroke-linecap="round" fill="none" />
      <circle cx="30" cy="92" r="4" fill="var(--rose, #E8B4B4)" />
    </g>
  )}

  {week === 6 && (
    <g>
      {/* Peak week + real smiles — a green smiley */}
      <circle cx="60" cy="58" r="30" fill="var(--leaf, #8FBC85)" />
      <circle cx="49" cy="52" r="3.5" fill="var(--ink, #3D443A)" />
      <circle cx="71" cy="52" r="3.5" fill="var(--ink, #3D443A)" />
      <path d="M45 65 q15 15 30 0" stroke="var(--ink, #3D443A)" stroke-width="3.5" stroke-linecap="round" fill="none" />
      <circle cx="34" cy="90" r="4" fill="var(--rose, #E8B4B4)" />
      <circle cx="88" cy="32" r="3.2" fill="var(--butter, #F2DFA8)" />
    </g>
  )}

  {week === 7 && (
    <g>
      {/* Cooing & conversations — a little face with sound waves */}
      <circle cx="46" cy="62" r="19" fill="var(--sage, #6B9A5F)" />
      <circle cx="40" cy="59" r="2.6" fill="#FFFFFF" />
      <circle cx="52" cy="59" r="2.6" fill="#FFFFFF" />
      <path d="M40 67 q6 5 12 0" stroke="#FFFFFF" stroke-width="2.5" stroke-linecap="round" fill="none" />
      <path d="M72 48 q11 14 0 28" stroke="var(--sage-deep, #557B4B)" stroke-width="3" stroke-linecap="round" fill="none" />
      <path d="M82 40 q17 22 0 44" stroke="var(--sage-deep, #557B4B)" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.6" />
      <circle cx="96" cy="32" r="3.5" fill="var(--butter, #F2DFA8)" />
    </g>
  )}

  {week === 8 && (
    <g>
      {/* Two months — a milestone badge */}
      <circle cx="60" cy="60" r="30" fill="var(--sage, #6B9A5F)" />
      <text x="60" y="74" text-anchor="middle" font-family="Georgia, serif" font-size="40" font-weight="600" fill="#FFFFFF">2</text>
      <path d="M60 28 l2.6 6 6 2.6 -6 2.6 -2.6 6 -2.6 -6 -6 -2.6 6 -2.6 Z" fill="var(--butter, #F2DFA8)" transform="translate(0,-6)" />
    </g>
  )}

  {week === 9 && (
    <g>
      {/* Discovering hands — batting at a dangling star */}
      <circle cx="60" cy="66" r="26" fill="var(--leaf, #8FBC85)" />
      <circle cx="51" cy="62" r="3.2" fill="var(--ink, #3D443A)" />
      <circle cx="69" cy="62" r="3.2" fill="var(--ink, #3D443A)" />
      <path d="M49 72 q11 10 22 0" stroke="var(--ink, #3D443A)" stroke-width="3" stroke-linecap="round" fill="none" />
      <line x1="60" y1="40" x2="60" y2="30" stroke="var(--sage-deep, #557B4B)" stroke-width="2" stroke-linecap="round" />
      <path d="M60 20 l2.2 5.2 5.2 2.2 -5.2 2.2 -2.2 5.2 -2.2 -5.2 -5.2 -2.2 5.2 -2.2 Z" fill="var(--butter, #F2DFA8)" />
    </g>
  )}

  {week === 10 && (
    <g>
      {/* First laughs — an open, happy face */}
      <circle cx="60" cy="58" r="30" fill="var(--sage, #6B9A5F)" />
      <path d="M45 51 q4 -5 8 0" stroke="#FFFFFF" stroke-width="3" stroke-linecap="round" fill="none" />
      <path d="M67 51 q4 -5 8 0" stroke="#FFFFFF" stroke-width="3" stroke-linecap="round" fill="none" />
      <path d="M48 63 q12 16 24 0 Z" fill="#FFFFFF" />
      <circle cx="90" cy="34" r="3" fill="var(--butter, #F2DFA8)" />
      <circle cx="30" cy="40" r="2.6" fill="var(--rose, #E8B4B4)" />
    </g>
  )}

  {week === 11 && (
    <g>
      {/* Hands to the middle — two little hands meeting */}
      <circle cx="60" cy="46" r="17" fill="var(--leaf, #8FBC85)" />
      <circle cx="54" cy="44" r="2.8" fill="var(--ink, #3D443A)" />
      <circle cx="66" cy="44" r="2.8" fill="var(--ink, #3D443A)" />
      <path d="M55 51 q5 4 10 0" stroke="var(--ink, #3D443A)" stroke-width="2.4" stroke-linecap="round" fill="none" />
      <ellipse cx="51" cy="80" rx="11" ry="5" transform="rotate(30 51 80)" fill="var(--sage, #6B9A5F)" />
      <ellipse cx="69" cy="80" rx="11" ry="5" transform="rotate(-30 69 80)" fill="var(--sage, #6B9A5F)" />
      <circle cx="60" cy="82" r="4.5" fill="var(--butter, #F2DFA8)" />
    </g>
  )}

  {week === 12 && (
    <g>
      {/* Three months — a milestone badge */}
      <circle cx="60" cy="60" r="30" fill="var(--sage, #6B9A5F)" />
      <text x="60" y="74" text-anchor="middle" font-family="Georgia, serif" font-size="40" font-weight="600" fill="#FFFFFF">3</text>
      <path d="M60 28 l2.6 6 6 2.6 -6 2.6 -2.6 6 -2.6 -6 -6 -2.6 6 -2.6 Z" fill="var(--butter, #F2DFA8)" transform="translate(0,-6)" />
    </g>
  )}

  {(week < 1 || week > 12) && (
    <g>
      <path d="M32 88 Q56 78 84 46" stroke="var(--sage-deep, #557B4B)" stroke-width="3" stroke-linecap="round" fill="none" />
      <ellipse cx="46" cy="80" rx="11" ry="5" transform="rotate(-22 46 80)" fill="var(--leaf, #8FBC85)" />
      <ellipse cx="62" cy="68" rx="11" ry="5" transform="rotate(-32 62 68)" fill="var(--sage, #6B9A5F)" />
      <ellipse cx="76" cy="55" rx="10" ry="4.5" transform="rotate(-38 76 55)" fill="var(--leaf, #8FBC85)" />
      <path d="M88 34 l2.4 5.8 5.8 2.4 -5.8 2.4 -2.4 5.8 -2.4 -5.8 -5.8 -2.4 5.8 -2.4 Z" fill="var(--butter, #F2DFA8)" />
    </g>
  )}
</svg>
