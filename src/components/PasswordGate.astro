---
import LeafSprig from './illustrations/LeafSprig.astro';

interface Props {
  next?: string;
  error?: string;
}

const { next = '/', error } = Astro.props;
---

<section class="gate">
  <div class="gate-card">
    <LeafSprig width={64} />
    <p class="eyebrow gate-eyebrow">Private</p>
    <h1 class="gate-title">Family &amp; friends only</h1>
    <p class="gate-blurb">
      Enter the shared password to see the week-by-week guide and journal.
    </p>

    <form method="POST" action="/api/login" class="gate-form" autocomplete="off">
      <input type="hidden" name="next" value={next} />
      <label for="password" class="gate-label">Password</label>
      <input
        type="password"
        id="password"
        name="password"
        required
        autocomplete="current-password"
        autofocus
      />
      {error && <p class="gate-error" role="alert">{error}</p>}
      <button type="submit" class="gate-submit">Enter</button>
    </form>
  </div>
</section>

<style>
  .gate {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2) var(--space-1);
    background: var(--surface-default);
  }

  .gate-card {
    width: 100%;
    max-width: 26rem;
    padding: var(--space-3);
    background: var(--surface-raised);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-lifted);
  }

  .gate-eyebrow {
    color: var(--accent-primary);
  }

  .gate-title {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: var(--fs-h2);
    margin: 0 0 var(--space-1);
    color: var(--text-primary);
  }

  .gate-blurb {
    color: var(--text-secondary);
    margin: 0 0 var(--space-2);
  }

  .gate-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .gate-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .gate-form input[type='password'] {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.75rem;
    border: 1px solid var(--border-hairline);
    background: var(--surface-default);
    color: var(--text-primary);
    border-radius: var(--radius-button);
  }

  .gate-form input[type='password']:focus-visible {
    outline: 2px solid var(--accent-calm);
    outline-offset: 2px;
  }

  .gate-error {
    color: var(--error);
    font-size: 0.875rem;
    margin: 0;
  }

  .gate-submit {
    margin-top: var(--space-1);
    padding: 0.75rem var(--space-2);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    background: var(--sage);
    border: none;
    border-radius: var(--radius-pill);
    cursor: pointer;
    min-height: 44px;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .gate-submit:hover {
    background: var(--sage-deep);
    transform: translateY(-2px);
  }

  .gate-submit:focus-visible {
    outline: 2px solid var(--accent-calm);
    outline-offset: 2px;
  }
</style>
