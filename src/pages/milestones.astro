---
import { getCollection } from 'astro:content';
import ContentLayout from '../layouts/ContentLayout.astro';
import MonthVignette from '../components/illustrations/MonthVignette.astro';
import { currentMonthNumber } from '../lib/current-week';

const months = (await getCollection('months', ({ data }) => !data.draft))
  .sort((a, b) => a.data.monthNumber - b.data.monthNumber);
const active = currentMonthNumber();

// Each stop: number, title, link, up-to-3 headline milestones, current flag.
const stops = [
  {
    n: '1–3',
    title: 'The Newborn Weeks',
    href: '/weeks/',
    headlines: ['Surviving the shock, feeding & sleep', 'The crying curve and first smiles', 'Two months: the first shots'],
    current: active >= 1 && active <= 3,
    isLead: true,
  },
  ...months.map((m) => ({
    n: String(m.data.monthNumber),
    title: m.data.title,
    href: `/months/${String(m.data.monthNumber).padStart(2, '0')}/`,
    headlines: m.data.milestones.slice(0, 3).map((x) => x.title),
    current: m.data.monthNumber === active,
    monthNumber: m.data.monthNumber,
    isLead: false,
  })),
];
---

<ContentLayout
  eyebrow="Milestone timeline"
  title="The first year, growing"
  description="Every stage on one winding path. Tap any stop for the full page. Remember: ranges are wide — this is a map, not a scorecard."
  wide
>
  <ol class="vine">
    {stops.map((s, i) => (
      <li class:list={['stop', 'reveal', { 'is-current': s.current }]} style={`--reveal-delay:${i * 60}ms`}>
        <span class="node" aria-hidden="true"></span>
        <a class="card card-lift stop-card" href={s.href}>
          <span class="stop-art">
            {s.isLead ? <MonthVignette month={0} size={72} /> : <MonthVignette month={(s as any).monthNumber} size={72} />}
          </span>
          <span class="stop-body">
            <span class="stop-eyebrow">{s.isLead ? 'Months' : 'Month'} {s.n}{s.current ? ' · you are here' : ''}</span>
            <span class="stop-title">{s.title}</span>
            {s.headlines.length > 0 && (
              <ul class="stop-headlines">
                {s.headlines.map((h) => <li>{h}</li>)}
              </ul>
            )}
            <span class="stop-go">Open &rarr;</span>
          </span>
        </a>
      </li>
    ))}
  </ol>

  {months.length === 0 && (
    <p class="vine-note">The monthly stops appear as the month pages are published.</p>
  )}
</ContentLayout>

<style>
  .vine {
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0 0 0 2.5rem;
    position: relative;
  }
  /* The vine itself — a soft sage stem down the left. */
  .vine::before {
    content: '';
    position: absolute;
    left: 0.9rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 4px;
    border-radius: 2px;
    background: linear-gradient(var(--leaf), var(--sage) 60%, color-mix(in srgb, var(--sage) 40%, var(--ivory)));
  }
  .stop { position: relative; margin-bottom: var(--space-2); }
  .node {
    position: absolute;
    left: -1.85rem;
    top: 1.6rem;
    width: 1.1rem;
    height: 1.1rem;
    border-radius: 999px;
    background: var(--sage);
    box-shadow: 0 0 0 4px var(--ivory), 0 0 0 6px color-mix(in srgb, var(--sage) 30%, var(--ivory));
  }
  .stop.is-current .node { background: var(--butter); box-shadow: 0 0 0 4px var(--ivory), 0 0 0 7px var(--sage); }

  .stop-card { display: flex; gap: var(--space-1); align-items: flex-start; padding: var(--space-1) var(--space-2); text-decoration: none; color: var(--text-primary); }
  .stop.is-current .stop-card { background: color-mix(in srgb, var(--butter) 34%, var(--paper)); }
  .stop-art { flex-shrink: 0; }
  .stop-body { display: flex; flex-direction: column; gap: 0.25rem; }
  .stop-eyebrow { font-size: var(--fs-eyebrow); font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; color: var(--sage-deep); }
  .stop-title { font-family: var(--font-heading); font-weight: 560; font-size: var(--fs-h3); line-height: 1.15; }
  .stop-headlines { margin: 0.35rem 0 0; padding-left: 1.1rem; color: var(--text-secondary); }
  .stop-headlines li { margin-bottom: 0.15rem; }
  .stop-go { margin-top: 0.5rem; font-weight: 700; color: var(--accent-primary); }
  .vine-note { color: var(--text-secondary); font-style: italic; margin-top: var(--space-2); }

  @media (max-width: 640px) {
    .stop-card { flex-direction: column; }
  }
</style>
