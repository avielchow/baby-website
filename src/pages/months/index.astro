---
import { getCollection } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import MonthVignette from '../../components/illustrations/MonthVignette.astro';
import { currentMonthNumber } from '../../lib/current-week';

const months = (await getCollection('months', ({ data }) => !data.draft))
  .sort((a, b) => a.data.monthNumber - b.data.monthNumber);
const activeMonth = currentMonthNumber();
---

<ContentLayout
  eyebrow="The baby guide"
  title="Month by month, 4–12 months"
  description="From the first three months, the guide shifts to a page per month — milestones, feeding, sleep, safety as they get moving, and what to buy. Same sourced, honest approach."
  wide
>
  {months.length === 0 ? (
    <p>The monthly pages are being written — check back soon.</p>
  ) : (
    <ul class="week-list">
      {months.map((m, i) => {
        const slug = String(m.data.monthNumber).padStart(2, '0');
        const isCurrent = m.data.monthNumber === activeMonth;
        return (
          <li class:list={['card', 'card-lift', 'week-item', 'reveal', { 'is-current': isCurrent }]} style={`--reveal-delay: ${(i % 4) * 70}ms`}>
            <a href={`/months/${slug}/`} class="week-link">
              <MonthVignette month={m.data.monthNumber} size={92} class="week-art" />
              <span class="week-num" aria-hidden="true">{m.data.monthNumber}</span>
              <span class="week-text">
                <span class="week-label">Month {m.data.monthNumber}</span>
                <span class="week-title">{m.data.title}</span>
                {m.data.description && <span class="week-desc">{m.data.description}</span>}
              </span>
              {isCurrent && <span class="badge-butter week-flag">Now</span>}
            </a>
          </li>
        );
      })}
    </ul>
  )}

  <p class="back-newborn reveal">Looking for the earliest days? <a href="/weeks/">Newborn Weeks (the first 3 months) &rarr;</a></p>
</ContentLayout>

<style>
  .week-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-1); }
  .week-item.is-current { background: color-mix(in srgb, var(--butter) 36%, var(--paper)); }
  .week-link { display: flex; gap: var(--space-2); align-items: center; padding: var(--space-1) var(--space-2) var(--space-1) var(--space-1); text-decoration: none; color: var(--text-primary); }
  .week-art { flex-shrink: 0; }
  .week-num { font-family: var(--font-heading); font-weight: 600; font-variation-settings: 'opsz' 100; font-size: 4rem; line-height: 1; color: var(--sage); min-width: 2ch; text-align: center; }
  .week-text { flex: 1; display: flex; flex-direction: column; gap: 0.15rem; }
  .week-label { font-size: var(--fs-eyebrow); font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--sage-deep); }
  .week-title { font-family: var(--font-heading); font-weight: 560; font-size: var(--fs-h2); line-height: 1.15; }
  .week-desc { color: var(--text-secondary); margin-top: 0.35rem; }
  .week-flag { flex-shrink: 0; }
  .back-newborn { margin-top: var(--space-2); font-weight: 600; }
  @media (max-width: 640px) {
    .week-link { flex-wrap: wrap; gap: var(--space-1); }
    .week-num { display: none; }
    .week-text { flex-basis: 100%; order: 3; }
  }
</style>
