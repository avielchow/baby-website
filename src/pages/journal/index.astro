---
import { getCollection } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';

const entries = (await getCollection('journal', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Sneak peek: pull each entry's media straight from its markdown body —
// capture photos become thumbnails, the first YouTube embed becomes a
// play-badged tile (YouTube's own thumbnail CDN).
const MAX_PHOTO_THUMBS = 3;
const previews = entries.map((entry) => {
  const body = entry.body ?? '';
  const photos = [...new Set(
    [...body.matchAll(/\/api\/capture-photo\/[A-Za-z0-9.]+/g)].map((m) => m[0]),
  )];
  const video = body.match(/youtube-nocookie\.com\/embed\/([A-Za-z0-9_-]+)/)?.[1] ?? null;
  const shown = photos.slice(0, MAX_PHOTO_THUMBS);
  return { entry, photos: shown, more: photos.length - shown.length, video };
});
---

<ContentLayout
  eyebrow="Journal"
  title="Small stories"
  description="Reflections and moments as they arrive."
>
  {previews.length === 0 ? (
    <p>No entries yet.</p>
  ) : (
    <ul class="entry-list">
      {previews.map(({ entry, photos, more, video }) => (
        <li class="entry">
          <p class="entry-date">{entry.data.date.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}</p>
          <h2 class="entry-title"><a href={`/journal/${entry.id}/`}>{entry.data.title}</a></h2>
          {entry.data.teaser && <p class="entry-teaser">{entry.data.teaser}</p>}
          {(video || photos.length > 0) && (
            <a class="entry-media" href={`/journal/${entry.id}/`} aria-label={`Open “${entry.data.title}”`}>
              {video && (
                <span class="media-tile media-video">
                  <img src={`https://i.ytimg.com/vi/${video}/hqdefault.jpg`} alt="" loading="lazy" decoding="async" />
                  <span class="play-badge" aria-hidden="true">▶</span>
                </span>
              )}
              {photos.map((src, i) => (
                <span class="media-tile">
                  <img src={src} alt="" loading="lazy" decoding="async" />
                  {i === photos.length - 1 && more > 0 && (
                    <span class="more-badge">+{more}</span>
                  )}
                </span>
              ))}
            </a>
          )}
          {entry.data.tags.length > 0 && (
            <p class="entry-tags">{entry.data.tags.map((t) => <span class="tag">{t}</span>)}</p>
          )}
        </li>
      ))}
    </ul>
  )}
</ContentLayout>

<style>
  .entry-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .entry {
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border-hairline);
  }

  .entry:last-child { border-bottom: 0; }

  .entry-date {
    margin: 0;
    font-size: var(--fs-small);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .entry-title {
    margin: var(--space-half) 0 var(--space-1);
    font-size: var(--fs-h3);
    font-weight: 500;
  }

  .entry-title a {
    color: var(--text-primary);
    text-decoration: none;
  }

  .entry-title a:hover { color: var(--accent-primary); }

  .entry-teaser {
    color: var(--text-secondary);
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--fs-body-lg);
  }

  /* Media sneak peek: a strip of small tiles — video (16:9, play badge)
     leads, then photo thumbs, "+N" on the last when there are more. */
  .entry-media {
    display: flex;
    gap: var(--space-half);
    margin: var(--space-1) 0 0;
    text-decoration: none;
  }

  .media-tile {
    position: relative;
    display: block;
    height: 96px;
    aspect-ratio: 1;
    border-radius: var(--radius-button);
    overflow: hidden;
    flex: 0 0 auto;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .media-tile.media-video { aspect-ratio: 16 / 9; }

  .entry-media:hover .media-tile {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lifted);
  }

  .media-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .play-badge {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 1.25rem;
    background: rgba(0, 0, 0, 0.35);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.6);
  }

  .more-badge {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 700;
    font-size: 1.1rem;
    background: rgba(15, 20, 15, 0.55);
  }

  @media (max-width: 480px) {
    .media-tile { height: 72px; }
  }

  .entry-tags {
    margin: var(--space-1) 0 0;
    display: flex;
    gap: var(--space-half);
    flex-wrap: wrap;
  }

  .tag {
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.15em 0.6em;
    color: var(--accent-primary);
    background: color-mix(in srgb, var(--accent-primary) 12%, transparent);
    border-radius: 999px;
  }
</style>
