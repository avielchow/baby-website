---
import { getEntry, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import MediaLightbox from '../../components/MediaLightbox.astro';

const slug = Astro.params.slug;
if (!slug) return Astro.redirect('/journal/', 302);

// Drafts stay hidden in production but render in local dev (`npm run dev`)
// so entries can be previewed before publishing.
const entry = await getEntry('journal', slug);
if (!entry || (entry.data.draft && !import.meta.env.DEV)) {
  return new Response('Journal entry not found', { status: 404 });
}

const { Content } = await render(entry);
const dateLabel = entry.data.date.toLocaleDateString('en-CA', {
  year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC',
});
---

<ContentLayout
  eyebrow={dateLabel}
  title={entry.data.title}
  description={entry.data.teaser}
  lastUpdated={entry.data.lastUpdated}
>
  <div class="journal-prose lightbox-scope">
    <Content />
  </div>
  <MediaLightbox />

  {entry.data.tags.length > 0 && (
    <p class="entry-tags">{entry.data.tags.map((t) => <span class="tag">{t}</span>)}</p>
  )}

  <p class="entry-nav">
    <a href="/journal/">&larr; All entries</a>
  </p>
</ContentLayout>
<style>
  .journal-prose {
    font-size: var(--fs-body-lg);
    line-height: 1.7;
  }

  .journal-prose :global(p) {
    margin-bottom: var(--space-paragraph);
    max-width: none;
  }

  .journal-prose :global(h2) {
    margin-top: var(--space-3);
    font-size: var(--fs-h3);
    font-weight: 500;
  }

  .journal-prose :global(blockquote) {
    margin: var(--space-2) 0;
    padding-left: var(--space-1);
    border-left: 3px solid var(--accent-calm);
    color: var(--text-secondary);
    font-style: italic;
  }

  /* Photos render as a responsive thumbnail grid; tap/click opens the lightbox.
     Standard: wrap groups in <div class="photo-grid"> (see JOURNAL.md). Bare
     markdown images get the same thumbnail treatment. */
  .journal-prose :global(.photo-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: var(--space-half);
    margin: var(--space-2) 0;
  }

  .journal-prose :global(.photo-grid img),
  .journal-prose :global(p > img) {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: var(--radius-button);
    cursor: zoom-in;
    display: block;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .journal-prose :global(.photo-grid img:hover),
  .journal-prose :global(p > img:hover) {
    transform: scale(1.02);
    box-shadow: var(--shadow-lifted);
  }

  .journal-prose :global(p > img) {
    max-width: 320px;
  }

  @media (max-width: 480px) {
    .journal-prose :global(.photo-grid) {
      grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    }
  }

  /* Videos embed large and responsive: <div class="video-embed"><iframe …>. */
  .journal-prose :global(.video-embed) {
    margin: var(--space-2) 0;
  }

  .journal-prose :global(.video-embed iframe) {
    width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
    border: 0;
    border-radius: var(--radius-card);
    display: block;
  }

  .entry-tags {
    margin: var(--space-2) 0 0;
    display: flex;
    gap: var(--space-half);
    flex-wrap: wrap;
  }

  .tag {
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.15em 0.6em;
    color: var(--accent-primary);
    background: color-mix(in srgb, var(--accent-primary) 12%, transparent);
    border-radius: 999px;
  }

  .entry-nav {
    margin-top: var(--space-3);
    font-weight: 600;
  }
</style>
