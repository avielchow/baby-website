---
import { getCollection } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import WeekVignette from '../../components/illustrations/WeekVignette.astro';
import { currentWeekNumber } from '../../lib/current-week';

const weeks = (await getCollection('weeks', ({ data }) => !data.draft))
  .sort((a, b) => a.data.weekNumber - b.data.weekNumber);

const now = new Date();
const activeWeek = currentWeekNumber(now);
---

<ContentLayout
  eyebrow="Guide"
  title="Week by week"
  description="Each week has a page. Practical, sourced, and revised as we learn what's actually useful."
  wide
>
  {weeks.length === 0 ? (
    <p>No weeks published yet.</p>
  ) : (
    <ul class="week-list">
      {weeks.map((week, i) => {
        const slug = String(week.data.weekNumber).padStart(2, '0');
        const isCurrent = week.data.weekNumber === activeWeek;
        return (
          <li
            class:list={['card', 'card-lift', 'week-item', 'reveal', { 'is-current': isCurrent }]}
            style={`--reveal-delay: ${(i % 4) * 70}ms`}
          >
            <a href={`/weeks/${slug}/`} class="week-link">
              <WeekVignette week={week.data.weekNumber} size={92} class="week-art" />
              <span class="week-num" aria-hidden="true">{week.data.weekNumber}</span>
              <span class="week-text">
                <span class="week-label">Week {week.data.weekNumber}</span>
                <span class="week-title">{week.data.title}</span>
                {week.data.description && <span class="week-desc">{week.data.description}</span>}
              </span>
              {isCurrent && <span class="badge-butter week-flag">Current</span>}
            </a>
          </li>
        );
      })}
    </ul>
  )}
</ContentLayout>

<style>
  .week-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .week-item.is-current {
    background: color-mix(in srgb, var(--butter) 36%, var(--paper));
  }

  .week-link {
    display: flex;
    gap: var(--space-2);
    align-items: center;
    padding: var(--space-1) var(--space-2) var(--space-1) var(--space-1);
    text-decoration: none;
    color: var(--text-primary);
  }

  .week-art { flex-shrink: 0; }

  /* Giant Fraunces numeral as a graphic element (docs/DESIGN.md § Typography). */
  .week-num {
    font-family: var(--font-heading);
    font-weight: 600;
    font-variation-settings: 'opsz' 100;
    font-size: 4rem;
    line-height: 1;
    color: var(--sage);
    min-width: 2ch;
    text-align: center;
  }

  .week-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .week-label {
    font-size: var(--fs-eyebrow);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sage-deep);
  }

  .week-title {
    font-family: var(--font-heading);
    font-weight: 560;
    font-size: var(--fs-h2);
    line-height: 1.15;
  }

  .week-desc {
    color: var(--text-secondary);
    margin-top: 0.35rem;
  }

  .week-flag { flex-shrink: 0; }

  @media (max-width: 640px) {
    .week-link {
      flex-wrap: wrap;
      gap: var(--space-1);
    }
    .week-num { display: none; }
    .week-text { flex-basis: 100%; order: 3; }
  }
</style>
