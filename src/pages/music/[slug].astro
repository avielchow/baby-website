---
import { getEntry } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import PianoChord from '../../components/PianoChord.astro';
import VideoCard from '../../components/VideoCard.astro';
import Comments from '../../components/Comments.astro';

const slug = Astro.params.slug;
if (!slug) return Astro.redirect('/music/', 302);

const entry = await getEntry('music', slug);
if (!entry || entry.data.draft) return new Response('Not found', { status: 404 });
const d = entry.data;

const playerData = JSON.stringify({
  tempo: d.tempo,
  chords: d.progression.chords.map((c) => ({ bass: c.bass, notes: c.notes })),
});
---

<ContentLayout eyebrow={`Music · Week ${d.week}`} title={`"${d.title}"`} description={d.vibe} lastUpdated={d.lastUpdated}>
  <p class="music-meta reveal">
    <span class="meta-pill">{d.key}</span>
    <span class="meta-pill">{d.tempo} BPM</span>
    <span class="meta-pill">{d.progression.summary}</span>
  </p>

  <section class="week-section" id="listen">
    <h2 class="section-head"><span class="section-icon" set:html={'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V6l11-2v12"/><circle cx="6" cy="18" r="3"/><circle cx="17" cy="16" r="3"/></svg>'} /> Listen first</h2>
    <p class="section-intro">This is the sound-world of the week — hear where the colors live before you play them.</p>
    <VideoCard title={d.listen.title} url={d.listen.url} channel={d.listen.channel} />
  </section>

  <section class="week-section" id="progression" data-player={playerData}>
    <h2 class="section-head"><span class="section-icon" set:html={'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M7 5v9M11 5v9M15 5v9M19 5v9"/></svg>'} /> The progression</h2>
    <p class="section-intro">Tap any chord to hear its exact voicing. Loop the whole thing and improvise over it — the loop is the backing band.</p>
    <div class="loop-bar card">
      <button type="button" class="btn" id="loop-btn" data-playing="false">▶ Loop the progression</button>
      <span class="loop-hint">{d.tempo} BPM · one chord per bar · sound on</span>
    </div>
    <ol class="chord-list">
      {d.progression.chords.map((c, i) => (
        <li class="chord card">
          <div class="chord-head">
            <button type="button" class="chord-play" data-bass={c.bass} data-notes={JSON.stringify(c.notes)} aria-label={`Play ${c.symbol}`}>▶</button>
            <div>
              <p class="chord-symbol">{c.symbol} <span class="chord-roman">{c.roman}</span></p>
              <p class="chord-why">{c.why}</p>
            </div>
          </div>
          <PianoChord notes={c.notes} bass={c.bass} color={c.color} />
        </li>
      ))}
    </ol>
    <p class="legend"><span class="lg lg-bass"></span> bass (left hand) <span class="lg lg-tone"></span> chord tones <span class="lg lg-color"></span> the color notes</p>
  </section>

  <section class="week-section" id="lh">
    <h2 class="section-head"><span class="section-icon" set:html={'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 11V7a2 2 0 0 1 4 0v4M10 11V5a2 2 0 0 1 4 0v6M14 11V6a2 2 0 0 1 4 0v7a6 6 0 0 1-6 6h-1a6 6 0 0 1-6-6v-2a2 2 0 0 1 4 0"/></svg>'} /> Left hand of the week: {d.lh.name}</h2>
    <p class="section-intro">{d.lh.description}</p>
    <ol class="steps-list">
      {d.lh.steps.map((s) => <li>{s}</li>)}
    </ol>
    <p class="lh-pattern card">One bar over {d.progression.chords[0].symbol}: <strong>{d.lh.pattern}</strong></p>
  </section>

  <section class="week-section" id="melody">
    <h2 class="section-head"><span class="section-icon" set:html={'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17c3-6 6 2 9-4s6 2 9-4"/></svg>'} /> Melody workshop: {d.melody.technique}</h2>
    <p class="section-intro">{d.melody.description}</p>
    <ul class="tools-list">
      {d.melody.tools.map((t) => <li>{t}</li>)}
    </ul>
    <h3 class="sub-head">Three seeds — grow your own tune from any of them</h3>
    <ol class="seed-list">
      {d.melody.seeds.map((s) => (
        <li class="seed card">
          <p class="seed-name">{s.name}</p>
          <p class="seed-phrase">{s.phrase}</p>
          <p class="seed-tip">{s.tip}</p>
        </li>
      ))}
    </ol>
  </section>

  <section class="week-section" id="theory">
    <h2 class="section-head"><span class="section-icon" set:html={'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6.5A5.5 5.5 0 1 1 6.5 12M12 6.5V2M12 6.5L8 3"/><circle cx="12" cy="12" r="9.5"/></svg>'} /> Theory bite: {d.theory.title}</h2>
    <ul class="theory-list">
      {d.theory.points.map((p) => <li>{p}</li>)}
    </ul>
  </section>

  <section class="week-section" id="practice">
    <h2 class="section-head"><span class="section-icon" set:html={'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13" r="8"/><path d="M12 9v4l2.5 2.5M9 2h6"/></svg>'} /> The practice recipe (~20 minutes)</h2>
    <ol class="practice-list">
      {d.practice.map((p) => (
        <li class="practice-item card">
          <span class="practice-min">{p.minutes} min</span>
          <span class="practice-what">{p.what}</span>
        </li>
      ))}
    </ol>
  </section>

  <Comments pageId={`music-${d.week}`} backPath={`/music/${slug}/`} />

  <p class="week-nav"><a href="/music/">&larr; All weeks</a></p>
</ContentLayout>

<script>
  // Soft piano-ish WebAudio voice: tap a chord to hear it; loop the progression.
  let ctx: AudioContext | null = null;
  const getCtx = () => (ctx ??= new AudioContext());

  const SEMI: Record<string, number> = { C: 0, 'C#': 1, Db: 1, D: 2, 'D#': 3, Eb: 3, E: 4, F: 5, 'F#': 6, Gb: 6, G: 7, 'G#': 8, Ab: 8, A: 9, 'A#': 10, Bb: 10, B: 11 };
  function freq(note: string): number | null {
    const m = note.trim().match(/^([A-G][#b]?)(\d)$/);
    if (!m) return null;
    const midi = (parseInt(m[2], 10) + 1) * 12 + SEMI[m[1]];
    return 440 * Math.pow(2, (midi - 69) / 12);
  }

  function voice(f: number, when: number, dur: number, gainDb = 1) {
    const ac = getCtx();
    const g = ac.createGain();
    const lp = ac.createBiquadFilter();
    lp.type = 'lowpass'; lp.frequency.value = Math.min(f * 5, 5200); lp.Q.value = 0.4;
    g.gain.setValueAtTime(0, when);
    g.gain.linearRampToValueAtTime(0.16 * gainDb, when + 0.012);
    g.gain.exponentialRampToValueAtTime(0.0001, when + dur);
    for (const detune of [-4, 3]) {
      const o = ac.createOscillator();
      o.type = 'triangle'; o.frequency.value = f; o.detune.value = detune;
      o.connect(lp); o.start(when); o.stop(when + dur + 0.05);
    }
    lp.connect(g); g.connect(ac.destination);
  }

  function playChord(bass: string, notes: string[], when: number, dur: number) {
    const fb = freq(bass); if (fb) voice(fb, when, dur, 1.25);
    notes.forEach((n, i) => { const f = freq(n); if (f) voice(f, when + 0.012 * i, dur, 0.9); });
  }

  let loopTimer: number | null = null;

  function init() {
    // Tap-a-chord (dataset.bound guards against double-binding: init runs at
    // module load AND on astro:page-load for the initial navigation)
    document.querySelectorAll<HTMLButtonElement>('.chord-play').forEach((btn) => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => {
        const notes = JSON.parse(btn.dataset.notes || '[]');
        playChord(btn.dataset.bass || '', notes, getCtx().currentTime + 0.02, 2.2);
      });
    });
    // Loop
    const section = document.querySelector<HTMLElement>('#progression');
    const loopBtn = document.querySelector<HTMLButtonElement>('#loop-btn');
    if (!section || !loopBtn || loopBtn.dataset.bound) return;
    loopBtn.dataset.bound = '1';
    const data = JSON.parse(section.dataset.player || '{}');
    const barSec = (60 / (data.tempo || 72)) * 4;
    const stop = () => {
      if (loopTimer !== null) { clearInterval(loopTimer); loopTimer = null; }
      loopBtn.dataset.playing = 'false';
      loopBtn.textContent = '▶ Loop the progression';
    };
    loopBtn.addEventListener('click', () => {
      if (loopBtn.dataset.playing === 'true') return stop();
      const ac = getCtx();
      let bar = 0;
      const scheduleBar = () => {
        const c = data.chords[bar % data.chords.length];
        playChord(c.bass, c.notes, ac.currentTime + 0.03, barSec * 0.98);
        bar++;
      };
      scheduleBar();
      loopTimer = window.setInterval(scheduleBar, barSec * 1000);
      loopBtn.dataset.playing = 'true';
      loopBtn.textContent = '■ Stop';
    });
    document.addEventListener('astro:before-swap', stop, { once: true });
  }
  init();
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .music-meta { display: flex; gap: var(--space-half); flex-wrap: wrap; max-width: none; }
  .meta-pill { font-size: var(--fs-eyebrow); font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; color: var(--sage-deep); background: var(--sage-wash); padding: 0.3em 0.9em; border-radius: var(--radius-pill); }

  .week-section { margin-block: var(--space-3); }
  .section-head { display: flex; align-items: center; gap: var(--space-half); font-size: var(--fs-h2); margin-bottom: var(--space-1); }
  .section-icon { display: inline-flex; width: 2.4rem; height: 2.4rem; padding: 0.5rem; border-radius: var(--radius-pill); background: var(--sage-wash); color: var(--sage-deep); flex-shrink: 0; }
  .section-icon :global(svg) { width: 100%; height: 100%; }
  .section-intro { color: var(--text-secondary); max-width: none; margin-bottom: var(--space-1); }
  .sub-head { margin-top: var(--space-2); }

  .loop-bar { display: flex; align-items: center; gap: var(--space-1); flex-wrap: wrap; padding: var(--space-1) var(--space-2); margin-bottom: var(--space-2); }
  .loop-hint { font-size: var(--fs-small); color: var(--text-secondary); }

  .chord-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-1); }
  .chord { padding: var(--space-1) var(--space-2); }
  .chord-head { display: flex; gap: var(--space-1); align-items: flex-start; }
  .chord-play { flex-shrink: 0; width: 2.6rem; height: 2.6rem; border: none; border-radius: var(--radius-pill); background: var(--sage); color: #fff; font-size: 1rem; cursor: pointer; transition: transform 0.2s var(--ease-spring), background 0.2s; }
  .chord-play:hover { background: var(--sage-deep); transform: scale(1.08); }
  .chord-symbol { margin: 0.2rem 0 0.2rem; font-family: var(--font-heading); font-weight: 600; font-size: var(--fs-h3); }
  .chord-roman { font-size: 0.95rem; color: var(--sage-deep); font-weight: 700; margin-left: 0.4rem; }
  .chord-why { margin: 0; color: var(--text-secondary); max-width: none; }

  .legend { display: flex; gap: var(--space-1); align-items: center; flex-wrap: wrap; font-size: var(--fs-small); color: var(--text-secondary); margin-top: var(--space-1); }
  .lg { display: inline-block; width: 0.9rem; height: 0.9rem; border-radius: 3px; }
  .lg-bass { background: var(--sage-deep); }
  .lg-tone { background: var(--sage); }
  .lg-color { background: var(--rose); }

  .steps-list { padding-left: 1.4rem; max-width: none; }
  .steps-list li { margin-bottom: var(--space-half); }
  .lh-pattern { padding: var(--space-1) var(--space-2); max-width: none; }

  .tools-list { padding-left: 1.4rem; max-width: none; }
  .tools-list li { margin-bottom: 0.35rem; }

  .seed-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-1); }
  .seed { padding: var(--space-1) var(--space-2); border-left: 4px solid var(--butter); }
  .seed-name { margin: 0 0 0.25rem; font-weight: 800; }
  .seed-phrase { margin: 0 0 0.3rem; font-family: var(--font-heading); font-size: 1.1rem; max-width: none; }
  .seed-tip { margin: 0; color: var(--text-secondary); font-size: var(--fs-small); max-width: none; }

  .theory-list { padding-left: 1.4rem; max-width: none; }
  .theory-list li { margin-bottom: var(--space-half); }

  .practice-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-half); }
  .practice-item { display: flex; gap: var(--space-1); align-items: baseline; padding: var(--space-1) var(--space-2); }
  .practice-min { flex-shrink: 0; font-weight: 800; color: var(--sage-deep); min-width: 3.5rem; }
  .practice-what { color: var(--text-primary); }

  .week-nav { margin-top: var(--space-3); font-weight: 700; }
  .week-nav a { text-decoration: none; }
</style>
