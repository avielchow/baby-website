# Copy to .env.local and edit locally. NEVER commit real secrets.

# bcrypt hash of the shared site password.
# Generate one with:
#   node -e "console.log(require('bcryptjs').hashSync('YOUR-PASSWORD', 10))"
# IMPORTANT: in .env.local you MUST escape each `$` as `\$` because dotenv
# interpolates. Example: SITE_PASSWORD_HASH=\$2b\$10\$AbC...
# In the Vercel dashboard, paste the raw hash unescaped.
SITE_PASSWORD_HASH=

# 32+ char random string used to HMAC-sign the auth cookie.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SIGNING_SECRET=

# Optional: bcrypt hash of the parents-only password. The login form accepts
# either password; this one additionally unlocks the /private journal.
# Leave empty to disable the private section. Same $-escaping rule as above.
PRIVATE_PASSWORD_HASH=
